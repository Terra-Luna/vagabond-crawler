<form class="vagabond-encounter-roller">

  <div class="encounter-tabs" role="tablist" aria-label="Encounter tools">
    <button type="button" role="tab" aria-controls="encounter-tabpanel" aria-selected="{{#if isBuildMode}}true{{else}}false{{/if}}" tabindex="{{#if isBuildMode}}0{{else}}-1{{/if}}" class="tab-btn {{#if isBuildMode}}active{{/if}}" data-mode="build">
      <i class="fas fa-hammer" aria-hidden="true"></i> Build Table
    </button>
    <button type="button" role="tab" aria-controls="encounter-tabpanel" aria-selected="{{#if isBrowseMode}}true{{else}}false{{/if}}" tabindex="{{#if isBrowseMode}}0{{else}}-1{{/if}}" class="tab-btn {{#if isBrowseMode}}active{{/if}}" data-mode="browse">
      <i class="fas fa-skull-crossbones" aria-hidden="true"></i> Browse NPCs
    </button>
    <button type="button" role="tab" aria-controls="encounter-tabpanel" aria-selected="{{#if isExistingMode}}true{{else}}false{{/if}}" tabindex="{{#if isExistingMode}}0{{else}}-1{{/if}}" class="tab-btn {{#if isExistingMode}}active{{/if}}" data-mode="existing">
      <i class="fas fa-table" aria-hidden="true"></i> Roll Tables
    </button>
    <button type="button" role="tab" aria-controls="encounter-tabpanel" aria-selected="{{#if isMonsterCreatorMode}}true{{else}}false{{/if}}" tabindex="{{#if isMonsterCreatorMode}}0{{else}}-1{{/if}}" class="tab-btn {{#if isMonsterCreatorMode}}active{{/if}}" data-mode="monsterCreator">
      <i class="fas fa-wand-magic-sparkles" aria-hidden="true"></i> Monster Creator
    </button>
  </div>
  <div id="encounter-tabpanel" role="tabpanel">

  {{!-- BUILD TABLE TAB --}}
  {{#if isBuildMode}}
  <div class="encounter-build-section">
    <div class="encounter-controls-row">
      <div class="control-group">
        <label>Die Type</label>
        <select class="die-select">
          {{#each dieTypes}}
          <option value="{{value}}" {{#if selected}}selected{{/if}}>{{value}}</option>
          {{/each}}
        </select>
      </div>
      <div class="control-group" style="flex:1">
        <label>Table Name</label>
        <input type="text" class="table-name-input" value="{{tableName}}" placeholder="e.g. Forest Encounters" />
      </div>
      <div class="control-group" style="align-self:flex-end">
        <button type="button" class="save-table"><i class="fas fa-save"></i> Save as Roll Table</button>
      </div>
    </div>

    <div class="encounter-slots-header">
      <span class="slot-num">#</span>
      <span class="slot-name">Monster (drag NPC from sidebar)</span>
      <span class="slot-appearing"># Appearing</span>
      <span></span>
    </div>

    <div class="encounter-slots">
      {{#each slots}}
      <div class="encounter-slot {{#unless name}}empty{{/unless}}" data-index="{{index}}">
        <span class="slot-num">{{number}}</span>
        <span class="slot-name">{{#if name}}{{name}}{{else}}<em>Drop NPC here</em>{{/if}}</span>
        {{#if name}}
          <input type="text" class="appearing-input" data-index="{{index}}" value="{{appearing}}" placeholder="1" style="width:60px" />
          <button type="button" class="clear-slot" data-index="{{index}}"><i class="fas fa-times"></i></button>
        {{else}}
          <span class="slot-appearing"></span>
          <span></span>
        {{/if}}
      </div>
      {{/each}}
    </div>

    <div class="encounter-actions">
      <button type="button" class="roll-encounter"><i class="fas fa-dice-d20"></i> Roll Encounter</button>
    </div>
  </div>
  {{/if}}

  {{!-- BROWSE NPCs TAB --}}
  {{#if isBrowseMode}}
  <div class="loot-npc-panel">
    <div class="loot-filter-panel">
      <h3>Filters</h3>
      <div class="loot-filter-row">
        <label>Source</label>
        <select class="browse-source-filter">
          {{#each browseSources}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="loot-filter-row">
        <label>Search</label>
        <input type="text" class="browse-search-input" placeholder="Filter by name..." />
      </div>
      <div class="loot-filter-row">
        <label>Creature Type</label>
        <select class="browse-type-filter">
          <option value="">All Types</option>
          {{#each browseBeingTypes}}
          <option value="{{this}}" {{#if (eq this ../browseTypeFilter)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="loot-filter-row">
        <label>TL Range</label>
        <div style="display:flex; gap:4px; align-items:center;">
          <input type="number" class="browse-tl-min" value="{{browseTlMin}}" placeholder="Min" step="0.1" style="width:55px;" />
          <span style="color:#888;">–</span>
          <input type="number" class="browse-tl-max" value="{{browseTlMax}}" placeholder="Max" step="0.1" style="width:55px;" />
        </div>
      </div>
      <p class="table-hint" style="margin-top:8px;">Drag NPCs from the list into Build Table slots.</p>
    </div>
    <div class="loot-list-panel browse-list-fill">
      <table class="loot-npc-table">
        <thead>
          <tr>
            <th style="width:32px;"></th>
            <th class="loot-sortable" data-sort="name">Name <i class="fas fa-sort"></i></th>
            <th class="loot-sortable" data-sort="beingType" style="width:90px;">Type <i class="fas fa-sort"></i></th>
            <th class="loot-sortable" data-sort="threatLevel" style="width:40px;">TL <i class="fas fa-sort"></i></th>
            <th class="loot-sortable" data-sort="hp"  style="width:50px; text-align:center;">HP <i class="fas fa-sort"></i></th>
            <th class="loot-sortable" data-sort="dpr" style="width:50px; text-align:center;">DPR <i class="fas fa-sort"></i></th>
            <th style="width:30px;"></th>
          </tr>
        </thead>
        <tbody>
          {{#each browseNpcs}}
          <tr class="loot-npc-row browse-npc-row" data-actor-id="{{id}}" data-uuid="{{uuid}}" data-name="{{name}}" data-appearing="{{appearing}}" draggable="true">
            <td class="loot-npc-img" title="Double-click to inspect"><img src="{{img}}" width="28" height="28" style="border-radius:3px;" /></td>
            <td class="loot-npc-name" title="Double-click to inspect">{{name}}</td>
            <td class="loot-npc-type" style="font-size:0.8em; color:#aaa;">{{beingType}}</td>
            <td class="loot-npc-tl"  style="text-align:center;">{{threatLevelDisplay}}</td>
            <td class="loot-npc-hp"  style="text-align:center;">{{hp}}</td>
            <td class="loot-npc-dpr" style="text-align:center;">{{dpr}}</td>
            <td><button type="button" class="browse-add-btn" title="Add to encounter table" aria-label="Add {{name}} to encounter table"><i class="fas fa-plus" aria-hidden="true"></i></button></td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{#unless browseNpcs.length}}
      <p style="text-align:center; color:#888; padding:20px;">No NPCs found matching filters.</p>
      {{/unless}}
    </div>
  </div>
  {{/if}}

  {{!-- ROLL TABLES TAB --}}
  {{#if isExistingMode}}
  <div class="encounter-existing-section">
    {{#if registeredTable}}
    <div class="registered-table-group">
      <h4><i class="fas fa-star"></i> Active Table</h4>
      <div class="table-select-row">
        <span class="active-table-name">{{registeredTable}}</span>
        <button type="button" class="roll-registered"><i class="fas fa-dice-d20"></i> Roll</button>
      </div>
    </div>
    {{/if}}

    {{#if hasWorldTables}}
    <div class="world-tables-group">
      <h4><i class="fas fa-table"></i> All Roll Tables</h4>
      <p class="table-hint">Tables built here include monster UUIDs for token placement.</p>
      <div class="table-select-row">
        <select class="world-table-select">
          {{#each worldTableGroups}}
            {{#if label}}
            <optgroup label="{{label}}">
              {{#each tables}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
              {{/each}}
            </optgroup>
            {{else}}
              {{#each tables}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
              {{/each}}
            {{/if}}
          {{/each}}
        </select>
        <button type="button" class="roll-world-table"><i class="fas fa-dice-d20"></i> Roll</button>
        <button type="button" class="set-as-active"><i class="fas fa-star"></i> Set Active</button>
        <button type="button" class="manage-folders" title="Exclude folders from this list"><i class="fas fa-folder-minus"></i></button>
      </div>
      {{#if selectedTablePreview}}
      <div class="table-preview">
        <div class="table-preview-header">
          <span class="preview-formula">{{selectedTablePreview.formula}}</span>
        </div>
        <div class="table-preview-rows">
          {{#each selectedTablePreview.rows}}
          <div class="preview-row">
            <span class="preview-range">{{range}}</span>
            <span class="preview-name">{{name}}</span>
            <span class="preview-appearing">×{{appearing}}</span>
          </div>
          {{/each}}
        </div>
      </div>
      {{/if}}
    </div>
    {{else}}
    <p class="no-tables-msg"><em>No roll tables found. Build one in the Build Table tab.</em></p>
    {{/if}}
  </div>
  {{/if}}

  {{!-- MONSTER CREATOR TAB --}}
  {{!-- The Creator mounts its full UI into this container (see
       MonsterCreator.mountPanel in encounter-tools.mjs). The id must match
       so the Creator's existing CSS selectors keep working. --}}
  {{#if isMonsterCreatorMode}}
  <div class="encounter-mc-panel" id="vagabond-crawler-monster-creator"></div>
  {{/if}}

  </div>{{!-- /tabpanel --}}

  {{!-- RESULT PANEL — lives OUTSIDE the tabpanel so it's tied to encounter
       rolls (Build / Browse / Roll Tables), not the Monster Creator tab. --}}
  {{#if lastResult}}
  {{#unless isMonsterCreatorMode}}
  <div class="encounter-result-panel">
    <h4><img class="vcb-icon-dragon" src="modules/vagabond-crawler/icons/light-sabers.svg" alt="" /> Encounter Result</h4>

    {{#if lastResult.isMultiGroup}}
    <div class="result-row" style="flex-direction:column; align-items:stretch;">
      <div style="display:flex; align-items:center; gap:6px; margin-bottom:4px;">
        <span class="result-label">Monsters:</span>
        <button type="button" class="reroll-count" title="Re-roll all counts"><i class="fas fa-dice"></i></button>
      </div>
      {{#each lastResult.groups}}
      <div class="result-row" style="padding-left:12px;">
        <span class="result-value">{{name}} × {{count}} <small>({{formula}})</small></span>
      </div>
      {{/each}}
    </div>
    {{else}}
    <div class="result-row">
      <span class="result-label">Monster:</span>
      <span class="result-value">{{lastResult.monsterName}} × {{lastResult.count}}</span>
      <button type="button" class="reroll-count" title="Re-roll count"><i class="fas fa-dice"></i></button>
    </div>
    {{/if}}

    <div class="result-row">
      <span class="result-label">Distance:</span>
      <span class="result-value">{{lastResult.distance.label}} <small>({{lastResult.distance.roll}})</small></span>
      <button type="button" class="reroll-distance" title="Re-roll distance"><i class="fas fa-dice"></i></button>
    </div>
    <div class="result-row">
      <span class="result-label">Reaction:</span>
      <span class="result-value">{{lastResult.reaction.label}} <small>({{lastResult.reaction.roll}})</small></span>
      <button type="button" class="reroll-reaction" title="Re-roll reaction"><i class="fas fa-dice"></i></button>
    </div>
    <div class="result-actions">
      <button type="button" class="post-to-chat"><i class="fas fa-comment"></i> Post to Chat</button>
      {{#if lastResult.isMultiGroup}}
      <button type="button" class="place-tokens"><i class="fas fa-map-pin"></i> Place {{lastResult.count}} Token(s)</button>
      {{else}}
      {{#if lastResult.monsterUuid}}
      <button type="button" class="place-tokens"><i class="fas fa-map-pin"></i> Place {{lastResult.count}} Token(s)</button>
      {{/if}}
      {{/if}}
    </div>
  </div>
  {{/unless}}
  {{/if}}

</form>
