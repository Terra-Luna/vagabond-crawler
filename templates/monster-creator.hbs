<div class="mc-container">

  <div class="mc-scrollable">
  {{!-- Action buttons row (Reset is outside the Load collapsible so it's always reachable) --}}
  <div class="mc-top-actions">
    <button type="button" data-action="reset" class="mc-btn mc-btn-soft" title="Start fresh"><i class="fas fa-undo"></i> Reset</button>
    {{#if sourceName}}<div class="mc-load-hint">Based on: <strong>{{sourceName}}</strong> <span class="mc-hint">(compendium is not modified)</span></div>{{/if}}
  </div>

  {{!-- Load from bestiary (collapsible, with filter+list) --}}
  <details class="mc-section mc-collapsible" data-collapse="bestiary" {{#if sectionOpen.bestiary}}open{{/if}}>
    <summary data-action="toggleBestiary">
      <span class="mc-collapse-title"><i class="fas fa-book-open"></i> Load from Bestiary</span>
      <span class="mc-collapse-summary">
        <span class="mc-hint">{{bestiaryTotal}} monsters</span>
      </span>
    </summary>
    <div class="mc-bestiary-panel">
      <div class="mc-bestiary-filters">
        <input type="text" class="mc-filter-search" data-action="filterSearch" value="{{filters.search}}" placeholder="Search name…" />
        <select data-action="filterType">
          <option value="">All Types</option>
          {{#each beingTypeFilterOpts}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
        <select data-action="filterTL">
          <option value="">All TL</option>
          {{#each tlFilterOpts}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
        <select data-action="filterSource">
          <option value="">All Sources</option>
          {{#each sourceFilterOpts}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </div>
      <div class="mc-bestiary-count">Showing {{bestiaryShown}} of {{bestiaryTotal}}</div>
      <div class="mc-bestiary-list">
        {{#each filtered}}
        <div class="mc-bestiary-item" data-uuid="{{uuid}}">
          <span class="mc-bestiary-tl">{{tl}}</span>
          <span class="mc-bestiary-name">{{name}}</span>
          <span class="mc-bestiary-meta">{{beingType}}</span>
        </div>
        {{else}}
        <div class="mc-bestiary-empty">No monsters match these filters.</div>
        {{/each}}
      </div>
    </div>
  </details>

  {{!-- Identity + Images (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="identity" {{#if sectionOpen.identity}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Identity</span>
      <span class="mc-collapse-summary"><span class="mc-collapse-preview">{{identitySummary}}</span></span>
    </summary>
    <div class="mc-row">
      <div class="mc-field mc-wide">
        <label>Name</label>
        <input name="name" value="{{data.name}}" placeholder="Monster name…" />
      </div>
      <div class="mc-field mc-img-field">
        <label>Portrait</label>
        <div class="mc-img-row">
          <img class="mc-img-preview" src="{{data.portraitImg}}" />
          <button type="button" data-action="pickPortrait" class="mc-btn mc-btn-soft"><i class="fas fa-image"></i></button>
        </div>
      </div>
      <div class="mc-field mc-img-field">
        <label>Token</label>
        <div class="mc-img-row">
          <img class="mc-img-preview" src="{{data.tokenImg}}" />
          <button type="button" data-action="pickToken" class="mc-btn mc-btn-soft"><i class="fas fa-user-astronaut"></i></button>
        </div>
      </div>
      {{#if tokenizerAvailable}}
      <div class="mc-field mc-img-field">
        <label>&nbsp;</label>
        <button type="button" data-action="tokenize" class="mc-btn mc-btn-soft" title="Use Tokenizer to generate a portrait + token from an upload or URL (both will be updated on save)">
          <i class="fas fa-wand-magic-sparkles"></i> Tokenize…
        </button>
      </div>
      {{/if}}
    </div>
    <div class="mc-row">
      <div class="mc-field">
        <label>Being Type</label>
        <select name="beingType">
          {{#each beingTypes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </div>
      <div class="mc-field">
        <label>Size</label>
        <select name="size">
          {{#each sizes}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </div>
      <div class="mc-field">
        <label>Zone</label>
        <select name="zone">
          {{#each zones}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </div>
    </div>
  </details>

  {{!-- Stats (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="stats" {{#if sectionOpen.stats}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Stats</span>
      <span class="mc-collapse-summary"><span class="mc-collapse-preview">{{statsSummary}}</span></span>
    </summary>
    <div class="mc-row">
      <div class="mc-field mc-num"><label for="mc-field-hd">HD</label><input id="mc-field-hd" type="number" name="hd" min="1" max="30" value="{{data.hd}}" /></div>
      <div class="mc-field mc-num"><label for="mc-field-armor">Armor</label><input id="mc-field-armor" type="number" name="armor" min="0" max="10" value="{{data.armor}}" /></div>
      <div class="mc-field mc-wide">
        <label for="mc-field-armorDescription">Armor Description</label>
        <select id="mc-field-armorDescription" name="armorDescription">
          <option value="" {{#unless data.armorDescription}}selected{{/unless}}>— Pick armor type —</option>
          {{#each armorDescriptors}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </div>
      <div class="mc-field mc-num"><label for="mc-field-morale">Morale</label><input id="mc-field-morale" type="number" name="morale" min="2" max="12" value="{{data.morale}}" /></div>
    </div>
    <div class="mc-row">
      <div class="mc-field mc-num"><label for="mc-field-speed">Speed (walk)</label><input id="mc-field-speed" type="number" name="speed" min="0" step="5" value="{{data.speed}}" /></div>
      <div class="mc-field mc-num"><label for="mc-field-appearing">Appearing</label><input id="mc-field-appearing" name="appearing" value="{{data.appearing}}" placeholder="1, 2d6" /></div>
    </div>
    {{!-- Senses (collapsible mini-section — Token Vision lives inside) --}}
    <details class="mc-mini-collapsible" data-collapse="senses" {{#if sectionOpen.senses}}open{{/if}}>
      <summary class="mc-mini-head">
        <span class="mc-subhead">Senses</span>
        <span class="mc-collapse-preview">{{sensesPreview}}</span>
      </summary>
      <div class="mc-senses-grid">
        {{#each sensesGrid}}
        <label class="mc-sense-row">
          <input type="checkbox" data-sense="{{key}}" {{#if checked}}checked{{/if}} />
          <span class="mc-sense-label">{{label}}</span>
        </label>
        {{/each}}
      </div>
      <div class="mc-row mc-senses-other">
        <div class="mc-field mc-wide">
          <label>Other / Custom</label>
          <input type="text" data-senses-other value="{{data.sensesOther}}"
                 placeholder="Additional senses (free text)" />
        </div>
      </div>

      {{!-- Token Vision is now a small sub-group inside Senses. Angle is gone;
           blank range on a non-basic mode means infinite. --}}
      <div class="mc-vision-subgroup">
        <label class="mc-cb-row mc-vision-enable">
          <input type="checkbox" data-vision-field="visionEnabled" {{#if data.visionEnabled}}checked{{/if}} />
          <span>Vision enabled</span>
          <span class="mc-hint">— {{visionSummary}}</span>
        </label>
        <div class="mc-row">
          <div class="mc-field mc-wide">
            <label>Mode</label>
            <select data-vision-field="visionMode">
              {{#each visionModeOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
            </select>
          </div>
          <div class="mc-field mc-num">
            <label>Range (ft)</label>
            <input type="number" min="0" step="5"
                   data-vision-field="visionRange"
                   value="{{data.visionRange}}"
                   {{#if visionRangeDisabled}}disabled{{/if}}
                   placeholder="{{visionRangePlaceholder}}" />
          </div>
          <div class="mc-field" style="flex: 0 0 auto;">
            <button type="button" class="mc-btn mc-btn-soft" data-action="autoVisionFromSenses" title="Fill vision from the Senses checkboxes above">
              <i class="fas fa-magic"></i> Auto
            </button>
          </div>
        </div>
      </div>
    </details>

    {{!-- Other Movement Modes (collapsible mini-section) --}}
    <details class="mc-mini-collapsible" data-collapse="movement" {{#if sectionOpen.movement}}open{{/if}}>
      <summary class="mc-mini-head">
        <span class="mc-subhead">Other Movement Modes</span>
        <span class="mc-collapse-preview">{{movementPreview}}</span>
      </summary>
      <div class="mc-speedmode-grid">
        {{#each speedModesGrid}}
        <label class="mc-speedmode-row">
          <input type="checkbox" data-speedmode="{{value}}" {{#if checked}}checked{{/if}} />
          <span class="mc-speedmode-label">{{label}}</span>
          <input type="number" class="mc-speedmode-num" data-speedspeed="{{value}}"
                 min="0" step="5" value="{{speed}}" {{#unless checked}}disabled{{/unless}} />
          <span class="mc-hint">ft</span>
        </label>
        {{/each}}
      </div>
    </details>
  </details>

  {{!-- Damage Immunities (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="immunities" {{#if sectionOpen.immunities}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Damage Immunities</span>
      <span class="mc-collapse-summary">
        {{#if immunitiesSummary.hasAny}}
          <span class="mc-pill">{{immunitiesSummary.count}}</span>
          <span class="mc-collapse-preview">{{immunitiesSummary.preview}}</span>
        {{else}}
          <span class="mc-collapse-preview mc-empty">none</span>
        {{/if}}
      </span>
    </summary>
    <div class="mc-cb-grid">
      {{#each immunitiesGrid}}
      <label class="mc-cb-row"><input type="checkbox" data-immune="{{value}}" {{#if checked}}checked{{/if}} /><span>{{label}}</span></label>
      {{/each}}
    </div>
  </details>

  {{!-- Damage Weaknesses (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="weaknesses" {{#if sectionOpen.weaknesses}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Damage Weaknesses</span>
      <span class="mc-collapse-summary">
        {{#if weaknessesSummary.hasAny}}
          <span class="mc-pill">{{weaknessesSummary.count}}</span>
          <span class="mc-collapse-preview">{{weaknessesSummary.preview}}</span>
        {{else}}
          <span class="mc-collapse-preview mc-empty">none</span>
        {{/if}}
      </span>
    </summary>
    <div class="mc-cb-grid">
      {{#each weaknessesGrid}}
      <label class="mc-cb-row"><input type="checkbox" data-weak="{{value}}" {{#if checked}}checked{{/if}} /><span>{{label}}</span></label>
      {{/each}}
    </div>
  </details>

  {{!-- Status Immunities (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="statusImmunities" {{#if sectionOpen.statusImmunities}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Status Immunities</span>
      <span class="mc-collapse-summary">
        {{#if statusImmunitiesSummary.hasAny}}
          <span class="mc-pill">{{statusImmunitiesSummary.count}}</span>
          <span class="mc-collapse-preview">{{statusImmunitiesSummary.preview}}</span>
        {{else}}
          <span class="mc-collapse-preview mc-empty">none</span>
        {{/if}}
      </span>
    </summary>
    <div class="mc-cb-grid">
      {{#each statusImmunitiesGrid}}
      <label class="mc-cb-row"><input type="checkbox" data-statusimmune="{{value}}" {{#if checked}}checked{{/if}} /><span>{{label}}</span></label>
      {{/each}}
    </div>
  </details>

  {{!-- Actions (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="actions" {{#if sectionOpen.actions}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Actions</span>
      <span class="mc-collapse-summary">
        {{#if actionsSummary.count}}
          <span class="mc-pill">{{actionsSummary.count}}</span>
          <span class="mc-collapse-preview">{{actionsSummary.preview}}</span>
        {{else}}
          <span class="mc-collapse-preview mc-empty">none</span>
        {{/if}}
      </span>
    </summary>

    {{!-- Toolbar: add a blank action OR pick from a template popup --}}
    <div class="mc-action-toolbar">
      <button type="button" class="mc-btn mc-btn-primary" data-action="newBlankAction">
        <i class="fas fa-plus"></i> New Action
      </button>
      <div class="mc-template-picker">
        <button type="button" class="mc-btn mc-btn-soft" data-action="toggleTemplatePicker">
          <i class="fas fa-bolt"></i> From Template <i class="fas fa-caret-down"></i>
        </button>
        <div class="mc-template-popup{{#if templatePickerOpen}} mc-template-popup-open{{/if}}">
          {{#each quickPickGroups}}
          <div class="mc-template-group">
            <div class="mc-template-group-label">{{label}}</div>
            {{#each items}}
            <div class="mc-template-popup-row">
              <button type="button" class="mc-template-popup-btn" data-action="addTemplate" data-template-name="{{name}}">
                <strong>{{name}}</strong>
                <span class="mc-hint">{{previewDamage}}</span>
              </button>
            </div>
            {{/each}}
          </div>
          {{/each}}
        </div>
      </div>
    </div>

    <div class="mc-subsection">
      {{#if actionRows.length}}
      <div class="mc-action-list">
        {{#each actionRows}}
        <details class="mc-action-card" data-action-index="{{index}}" {{#if open}}open{{/if}}>
          <summary class="mc-action-summary">
            <span class="mc-action-summary-name">{{name}}</span>
            <span class="mc-action-summary-meta">{{attackTypeLabel}} · {{summary}}{{#if recharge}} · {{recharge}}{{/if}}{{#if causedStatuses.length}} · {{causedStatuses.length}} on-hit{{/if}}{{#if critCausedStatuses.length}} · {{critCausedStatuses.length}} crit{{/if}}</span>
            <button type="button" class="mc-action-delete" data-action="deleteAction" aria-label="Remove action {{name}}" title="Remove action"><i class="fas fa-times" aria-hidden="true"></i></button>
          </summary>

          {{!-- Two-column label/input grid --}}
          <div class="mc-action-grid">
            <label>Name</label>
            <input data-action-field="name" value="{{name}}" placeholder="Attack name" />

            <label>Type</label>
            <select data-action-field="attackType">
              {{#each attackTypeOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
            </select>

            <label>Damage</label>
            <div class="mc-action-dmgrow">
              <input class="mc-action-roll"  data-action-field="rollDamage" value="{{rollDamage}}" placeholder="2d6" />
              <span class="mc-hint">+</span>
              <input class="mc-action-flat"  data-action-field="flatDamage" value="{{flatDamage}}" placeholder="flat" />
              <select class="mc-action-dtype" data-action-field="damageType">
                {{#each damageTypeOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
              </select>
            </div>

            <label>Recharge</label>
            <input data-action-field="recharge" value="{{recharge}}" placeholder="Cd4" />

            <label>Weapon</label>
            <select class="mc-action-weapon-sel" data-action="setWeapon">
              {{#each weaponOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
            </select>

            <label>Note</label>
            <input data-action-field="note" value="{{note}}" placeholder="Melee Attack / Cast, Remote | Endure" />

            <label>Extra</label>
            <input data-action-field="extraInfo" value="{{extraInfo}}" placeholder="and Frightened (Cd4) / etc." />
          </div>

          {{!-- On-Hit Effects --}}
          <div class="mc-rider-block">
            <div class="mc-rider-head">
              <label class="mc-subhead">On-Hit Effects</label>
              <button type="button" class="mc-btn mc-btn-soft mc-rider-add" data-action="addOnHitEffect"><i class="fas fa-plus"></i> Add</button>
            </div>
            {{#each causedStatuses}}
            <div class="mc-rider-row" data-rider-list="causedStatuses" data-rider-index="{{@index}}">
              <select data-rider-field="statusId">{{#each statusOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
              <select data-rider-field="saveType">{{#each saveOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
              <input type="text" class="mc-rider-dur" data-rider-field="duration" value="{{duration}}" placeholder="d4 / d6" />
              <label class="mc-cb-row" title="Permanent — no duration"><input type="checkbox" data-rider-field="permanent" {{#if permanent}}checked{{/if}} /><span>Perm</span></label>
              <label class="mc-cb-row" title="Only applies when damage breaks armor"><input type="checkbox" data-rider-field="requiresDamage" {{#if requiresDamage}}checked{{/if}} /><span>If Hit</span></label>
              <label class="mc-cb-row" title="Tick damage (DoT)"><input type="checkbox" data-rider-field="tickDamageEnabled" {{#if tickDamageEnabled}}checked{{/if}} /><span>Tick</span></label>
              {{#if tickDamageEnabled}}
              <input type="text" class="mc-rider-tick" data-rider-field="damageOnTick" value="{{damageOnTick}}" placeholder="1d4" />
              <select class="mc-rider-dtype" data-rider-field="damageType">{{#each damageTypeOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
              {{/if}}
              <button type="button" class="mc-rider-delete" data-action="deleteRider" data-rider-list="causedStatuses" aria-label="Remove on-hit effect" title="Remove"><i class="fas fa-times" aria-hidden="true"></i></button>
            </div>
            {{/each}}
          </div>

          {{!-- Crit On-Hit Effects --}}
          <div class="mc-rider-block">
            <div class="mc-rider-head">
              <label class="mc-subhead">Crit On-Hit Effects</label>
              <button type="button" class="mc-btn mc-btn-soft mc-rider-add" data-action="addCritEffect"><i class="fas fa-plus"></i> Add</button>
            </div>
            {{#each critCausedStatuses}}
            <div class="mc-rider-row" data-rider-list="critCausedStatuses" data-rider-index="{{@index}}">
              <select data-rider-field="statusId">{{#each statusOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
              <select data-rider-field="saveType">{{#each saveOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
              <input type="text" class="mc-rider-dur" data-rider-field="duration" value="{{duration}}" placeholder="d4 / d6" />
              <label class="mc-cb-row"><input type="checkbox" data-rider-field="permanent" {{#if permanent}}checked{{/if}} /><span>Perm</span></label>
              <label class="mc-cb-row"><input type="checkbox" data-rider-field="requiresDamage" {{#if requiresDamage}}checked{{/if}} /><span>If Hit</span></label>
              <label class="mc-cb-row"><input type="checkbox" data-rider-field="tickDamageEnabled" {{#if tickDamageEnabled}}checked{{/if}} /><span>Tick</span></label>
              {{#if tickDamageEnabled}}
              <input type="text" class="mc-rider-tick" data-rider-field="damageOnTick" value="{{damageOnTick}}" placeholder="1d4" />
              <select class="mc-rider-dtype" data-rider-field="damageType">{{#each damageTypeOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}</select>
              {{/if}}
              <button type="button" class="mc-rider-delete" data-action="deleteRider" data-rider-list="critCausedStatuses" aria-label="Remove crit on-hit effect" title="Remove"><i class="fas fa-times" aria-hidden="true"></i></button>
            </div>
            {{/each}}
          </div>
        </details>
        {{/each}}
      </div>
      {{else}}
      <div class="mc-action-empty">No actions yet. Click <strong>+ New Action</strong> or <strong>+ From Template</strong> to add one.</div>
      {{/if}}
    </div>
  </details>

  {{!-- Abilities (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="abilities" {{#if sectionOpen.abilities}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Abilities</span>
      <span class="mc-collapse-summary">
        {{#if abilitiesSummary.count}}
          <span class="mc-pill">{{abilitiesSummary.count}}</span>
          <span class="mc-collapse-preview">{{abilitiesSummary.preview}}</span>
        {{else}}
          <span class="mc-collapse-preview mc-empty">none</span>
        {{/if}}
      </span>
    </summary>

    <div class="mc-subsection">
      <div class="mc-ability-browse-head">
        <input type="text" class="mc-ability-search" data-ability-search
               value="{{abilityQuery}}" placeholder="🔎 Search abilities…" />
        <div class="mc-ability-filters">
          {{#each abilityFilters}}
          <button type="button" class="mc-filter-btn {{#if active}}mc-filter-active{{/if}}"
                  data-ability-filter="{{key}}" title="{{title}}">
            {{label}} <span class="mc-hint">({{count}})</span>
          </button>
          {{/each}}
        </div>
      </div>

      <div class="mc-ability-browse-list">
        {{#each abilityTemplates}}
        <div class="mc-ability-browse-row" title="{{fullTooltip}}">
          <span class="mc-ability-browse-icon mc-badge-{{automationBadge.status}}" title="{{automationBadge.label}}">{{automationBadge.icon}}</span>
          <div class="mc-ability-browse-body">
            <div class="mc-ability-browse-title">
              {{name}}
              {{#if monsterCount}}<span class="mc-ability-usage" title="Used by {{monsterCount}} monster(s)">{{monsterCount}}</span>{{/if}}
            </div>
            <div class="mc-ability-browse-desc">{{representativeShort}}</div>
          </div>
          {{#if tiers}}
          <select class="mc-template-tier" data-ability-tier-for="{{name}}" title="Tier">
            {{#each tiers}}<option value="{{label}}">{{label}}</option>{{/each}}
          </select>
          {{/if}}
          {{#if variants}}
          <select class="mc-template-tier" data-ability-tier-for="{{name}}" title="Variant">
            {{#each variants}}<option value="{{label}}">{{label}}</option>{{/each}}
          </select>
          {{/if}}
          <button type="button" class="mc-btn mc-btn-soft mc-ability-add-btn"
                  data-action="addAbilityTemplate" data-template-name="{{name}}"
                  aria-label="Add ability {{name}}" title="Add">
            <i class="fas fa-plus" aria-hidden="true"></i>
          </button>
        </div>
        {{else}}
        <div class="mc-action-empty">No abilities match the current search / filter.</div>
        {{/each}}
      </div>
    </div>

    <div class="mc-subsection">
      <label class="mc-subhead">Current Abilities</label>
      {{#if abilityRows.length}}
      <div class="mc-ability-list">
        {{#each abilityRows}}
        <div class="mc-ability-row" data-ability-index="{{index}}">
          <div class="mc-ability-head">
            <input class="mc-action-name" data-ability-field="name" value="{{name}}" placeholder="Ability name" />
            {{#if badge}}
            <span class="mc-ability-badge mc-badge-{{badge.status}}" title="{{badge.label}}">{{badge.icon}} {{badge.label}}</span>
            {{/if}}
            <button type="button" class="mc-action-delete" data-action="deleteAbility" aria-label="Remove ability {{name}}" title="Remove"><i class="fas fa-times" aria-hidden="true"></i></button>
          </div>
          <textarea class="mc-ability-desc" data-ability-field="description" rows="2" placeholder="Description">{{description}}</textarea>
        </div>
        {{/each}}
      </div>
      {{else}}
      <div class="mc-action-empty">No abilities yet. Pick one above and click <i class="fas fa-plus"></i>.</div>
      {{/if}}
    </div>
  </details>

  {{!-- Mutations (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="mutations" {{#if sectionOpen.mutations}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Mutations</span>
      <span class="mc-collapse-summary">
        {{#if mutationSelectedCount}}
          <span class="mc-pill">{{mutationSelectedCount}}</span>
          <span class="mc-collapse-preview">
            HP {{mutationPreview.base.hp}}→{{mutationPreview.mutated.hp}} · Armor {{mutationPreview.base.armor}}→{{mutationPreview.mutated.armor}} · TL {{mutationPreview.base.tl}}→{{mutationPreview.mutated.tl}}
          </span>
        {{else}}
          <span class="mc-collapse-preview mc-empty">none selected</span>
        {{/if}}
      </span>
    </summary>

    <div class="mc-subsection">
      <div class="mc-mut-actions">
        <button type="button" class="mc-btn mc-btn-soft" data-action="rollRandomMutation" title="Roll one random boon + suggested bane">
          <i class="fas fa-dice-d20"></i> Roll Random
        </button>
        <button type="button" class="mc-btn mc-btn-primary" data-action="applyMutations" {{#unless mutationSelectedCount}}disabled{{/unless}}>
          <i class="fas fa-bolt"></i> Apply Selected
        </button>
        <button type="button" class="mc-btn mc-btn-soft" data-action="clearMutations" {{#unless mutationSelectedCount}}disabled{{/unless}}>Clear</button>
      </div>
    </div>

    {{#if mutationSelectedCount}}
    <div class="mc-subsection">
      <label class="mc-subhead">Preview</label>
      <div class="mc-mut-preview">
        <div>HP <strong>{{mutationPreview.base.hp}}</strong> → <strong class="mc-mut-delta">{{mutationPreview.mutated.hp}}</strong></div>
        <div>Armor <strong>{{mutationPreview.base.armor}}</strong> → <strong class="mc-mut-delta">{{mutationPreview.mutated.armor}}</strong></div>
        <div>Speed <strong>{{mutationPreview.base.speed}}</strong> → <strong class="mc-mut-delta">{{mutationPreview.mutated.speed}}</strong></div>
        <div>TL <strong>{{mutationPreview.base.tl}}</strong> → <strong class="mc-mut-delta">{{mutationPreview.mutated.tl}}</strong></div>
        <div>Abilities <strong>{{mutationPreview.base.abilityCount}}</strong> → <strong class="mc-mut-delta">{{mutationPreview.mutated.abilityCount}}</strong></div>
        <div>Actions <strong>{{mutationPreview.base.actionCount}}</strong> → <strong class="mc-mut-delta">{{mutationPreview.mutated.actionCount}}</strong></div>
      </div>
    </div>
    {{/if}}

    <div class="mc-subsection">
      <label class="mc-subhead">Mutation Browser</label>
      <div class="mc-template-tabs">
        {{#each mutationTabs}}
        <button type="button" class="mc-tab-btn {{#if active}}mc-tab-active{{/if}}" data-mutation-tab="{{key}}">{{label}}</button>
        {{/each}}
      </div>
      <div class="mc-mut-grid">
        {{#each mutationCards}}
        <label class="mc-mut-card mc-mut-{{type}} {{#if selected}}mc-mut-selected{{/if}} {{#if disabled}}mc-mut-disabled{{/if}}"
               title="{{description}}{{#if conflict}} — conflicts with another selected mutation{{/if}}">
          <input type="checkbox" data-mutation-id="{{id}}" {{#if selected}}checked{{/if}} {{#if disabled}}disabled{{/if}} />
          <span class="mc-mut-name">{{name}}</span>
          <span class="mc-mut-badge mc-mut-{{type}}-badge">{{type}}</span>
          <span class="mc-mut-tl">{{tlDeltaStr}}</span>
        </label>
        {{/each}}
      </div>
    </div>
  </details>

  {{!-- Description (collapsible) --}}
  <details class="mc-section mc-collapsible" data-collapse="description" {{#if sectionOpen.description}}open{{/if}}>
    <summary>
      <span class="mc-collapse-title">Description</span>
      <span class="mc-collapse-summary">
        {{#if descriptionPreview}}
          <span class="mc-collapse-preview">{{descriptionPreview}}</span>
        {{else}}
          <span class="mc-collapse-preview mc-empty">no description</span>
        {{/if}}
      </span>
    </summary>
    <textarea name="description" rows="3" placeholder="Optional lore / flavor…">{{data.description}}</textarea>
  </details>

  </div> {{!-- /mc-scrollable --}}

  {{!-- Preview + Actions (pinned to bottom; stays visible while mc-scrollable scrolls) --}}
  <div class="mc-footer">
    <div class="mc-preview-line">HP {{preview.hp}} · TL {{preview.tl}} · DPR {{#if actionsSummary.count}}{{preview.dpr}}{{else}}— (no actions){{/if}}</div>
    <div class="mc-footer-actions">
      <button type="button" data-action="cancel" class="mc-btn mc-btn-soft">Cancel</button>
      <button type="button" data-action="save" class="mc-btn mc-btn-primary"><i class="fas fa-save"></i> Create World Actor</button>
    </div>
  </div>

</div>
