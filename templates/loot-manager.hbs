<form class="vagabond-encounter-roller">

  <div class="encounter-tabs">
    <button type="button" class="tab-btn {{#if isBuildMode}}active{{/if}}" data-mode="build">
      <i class="fas fa-hammer"></i> Build Table
    </button>
    <button type="button" class="tab-btn {{#unless isBuildMode}}active{{/unless}}" data-mode="tables">
      <i class="fas fa-skull-crossbones"></i> NPC Loot
    </button>
  </div>

  {{!-- BUILD TABLE TAB --}}
  {{#if isBuildMode}}
  <div class="encounter-build-section">
    <div class="encounter-controls-row">
      <div class="control-group" style="flex:1">
        <label>Table Name</label>
        <input type="text" class="table-name-input" value="{{tableName}}" placeholder="e.g. Goblin Loot" />
      </div>
      <div class="control-group" style="align-self:flex-end">
        <button type="button" class="save-table"><i class="fas fa-save"></i> Save as Loot Table</button>
      </div>
    </div>

    <div class="encounter-slots-header">
      <span class="slot-num">#</span>
      <span class="slot-name">Item (drag from compendium or sidebar)</span>
      <span class="slot-appearing">Weight</span>
      <span></span>
    </div>

    <div class="encounter-slots">
      {{#each slots}}
      <div class="encounter-slot {{#unless name}}empty{{/unless}}" data-index="{{index}}">
        <span class="slot-num">{{number}}</span>
        {{#if name}}
        <span class="slot-name">
          <img src="{{img}}" width="24" height="24" style="border-radius:3px; vertical-align:middle; margin-right:4px;">
          {{name}}
        </span>
        <input type="text" class="appearing-input" data-index="{{index}}" value="{{weight}}" style="width:60px" />
        <button type="button" class="clear-slot" data-index="{{index}}"><i class="fas fa-times"></i></button>
        {{else}}
        <span class="slot-name"><em>Drop item here</em></span>
        <span class="slot-appearing"></span>
        <span></span>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- NPC LOOT TAB --}}
  {{#unless isBuildMode}}
  <div class="loot-npc-panel">

    {{!-- Left: Filters --}}
    <div class="loot-filter-panel">
      <h3>Filters</h3>
      <div class="loot-filter-row">
        <label>Source</label>
        <select class="loot-source-filter">
          {{#each sources}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="loot-filter-row">
        <label>Search</label>
        <input type="text" class="loot-search-input" placeholder="Filter by name..." />
      </div>
      <div class="loot-filter-row">
        <label>Creature Type</label>
        <select class="loot-type-filter">
          <option value="">All Types</option>
          {{#each beingTypes}}
          <option value="{{this}}" {{#if (eq this ../typeFilter)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="loot-filter-row">
        <label>TL Range</label>
        <div style="display:flex; gap:4px; align-items:center;">
          <input type="number" class="loot-tl-min" value="{{tlMin}}" placeholder="Min" step="0.1" style="width:55px;" />
          <span style="color:#888;">–</span>
          <input type="number" class="loot-tl-max" value="{{tlMax}}" placeholder="Max" step="0.1" style="width:55px;" />
        </div>
      </div>

      <h3 style="margin-top:12px;">Assign Table</h3>
      <div class="loot-filter-row">
        <select class="loot-assign-table">
          <option value="">— No Table —</option>
          {{#each tableGroups}}
            {{#if label}}
            <optgroup label="{{label}}">
              {{#each tables}}
              <option value="{{uuid}}">{{name}}</option>
              {{/each}}
            </optgroup>
            {{else}}
              {{#each tables}}
              <option value="{{uuid}}">{{name}}</option>
              {{/each}}
            {{/if}}
          {{/each}}
        </select>
      </div>
      <button type="button" class="loot-apply-btn" style="margin-top:4px; width:100%;">
        <i class="fas fa-check"></i> Apply to Selected
      </button>

      {{#if selectedTablePreview}}
      <h3 style="margin-top:8px;">Preview</h3>
      <div class="loot-table-preview-mini">
        <div style="font-size:0.8em; color:#888; margin-bottom:2px;">{{selectedTablePreview.formula}}</div>
        {{#each selectedTablePreview.rows}}
        <div style="display:flex; gap:4px; font-size:0.85em; padding:1px 0;">
          <span style="color:#888; width:30px;">{{range}}</span>
          {{#if img}}<img src="{{img}}" width="16" height="16" style="border-radius:2px;">{{/if}}
          <span style="flex:1;">{{name}}</span>
        </div>
        {{/each}}
      </div>
      {{/if}}
    </div>

    {{!-- Right: NPC List --}}
    <div class="loot-list-panel">
      <table class="loot-npc-table">
        <thead>
          <tr>
            <th style="width:28px;"><input type="checkbox" class="loot-select-all" title="Select all" /></th>
            <th style="width:32px;"></th>
            <th class="loot-sortable" data-sort="name">Name <i class="fas fa-sort"></i></th>
            <th class="loot-sortable" data-sort="beingType" style="width:90px;">Type <i class="fas fa-sort"></i></th>
            <th class="loot-sortable" data-sort="threatLevel" style="width:40px;">TL <i class="fas fa-sort"></i></th>
            <th style="width:130px;">Loot Table</th>
            <th style="width:42px;">%</th>
          </tr>
        </thead>
        <tbody>
          {{#each npcs}}
          <tr class="loot-npc-row" data-actor-id="{{id}}">
            <td><input type="checkbox" class="npc-select" data-actor-id="{{id}}" /></td>
            <td class="loot-npc-img" style="cursor:pointer;" title="Double-click to inspect"><img src="{{img}}" width="28" height="28" style="border-radius:3px;" /></td>
            <td class="loot-npc-name" style="cursor:pointer;" title="Double-click to inspect">{{name}}</td>
            <td class="loot-npc-type" style="font-size:0.8em; color:#aaa;">{{beingType}}</td>
            <td class="loot-npc-tl" style="text-align:center;">{{threatLevelDisplay}}</td>
            <td>
              {{#if isWorldActor}}
              <select class="npc-table-select" data-actor-id="{{id}}">
                <option value="">—</option>
                {{#each tableOptions}}
                <option value="{{uuid}}" {{#if selected}}selected{{/if}}>{{name}}</option>
                {{/each}}
              </select>
              {{else}}
              <span style="font-size:0.75em; color:#666;">compendium</span>
              {{/if}}
            </td>
            <td>
              {{#if isWorldActor}}
              <input type="number" class="npc-chance-input" data-actor-id="{{id}}" value="{{dropChance}}" min="-1" max="100" style="width:42px;" title="Drop chance % (-1 = global)" />
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{#unless npcs.length}}
      <p style="text-align:center; color:#888; padding:20px;">No NPCs found matching filters.</p>
      {{/unless}}
    </div>

  </div>
  {{/unless}}

</form>
