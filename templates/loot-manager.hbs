<form class="vagabond-encounter-roller">

  <div class="encounter-tabs">
    <button type="button" class="tab-btn {{#if isBuildMode}}active{{/if}}" data-mode="build">
      <i class="fas fa-hammer"></i> Build Table
    </button>
    <button type="button" class="tab-btn {{#unless isBuildMode}}active{{/unless}}" data-mode="tables">
      <i class="fas fa-table"></i> Loot Tables
    </button>
  </div>

  {{!-- BUILD TABLE TAB --}}
  {{#if isBuildMode}}
  <div class="encounter-build-section">
    <div class="encounter-controls-row">
      <div class="control-group" style="flex:1">
        <label>Table Name</label>
        <input type="text" class="table-name-input" value="{{tableName}}" placeholder="e.g. Goblin Loot" />
      </div>
      <div class="control-group" style="align-self:flex-end">
        <button type="button" class="save-table"><i class="fas fa-save"></i> Save as Loot Table</button>
      </div>
    </div>

    <div class="encounter-slots-header">
      <span class="slot-num">#</span>
      <span class="slot-name">Item (drag from compendium or sidebar)</span>
      <span class="slot-appearing">Weight</span>
      <span></span>
    </div>

    <div class="encounter-slots">
      {{#each slots}}
      <div class="encounter-slot {{#unless name}}empty{{/unless}}" data-index="{{index}}">
        <span class="slot-num">{{number}}</span>
        {{#if name}}
        <span class="slot-name">
          <img src="{{img}}" width="24" height="24" style="border-radius:3px; vertical-align:middle; margin-right:4px;">
          {{name}}
        </span>
        <input type="text" class="appearing-input" data-index="{{index}}" value="{{weight}}" style="width:60px" />
        <button type="button" class="clear-slot" data-index="{{index}}"><i class="fas fa-times"></i></button>
        {{else}}
        <span class="slot-name"><em>Drop item here</em></span>
        <span class="slot-appearing"></span>
        <span></span>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </div>
  {{/if}}

  {{!-- LOOT TABLES TAB --}}
  {{#unless isBuildMode}}
  <div class="encounter-existing-section">

    {{!-- All World Roll Tables --}}
    {{#if hasWorldTables}}
    <div class="world-tables-group">
      <h4><i class="fas fa-table"></i> All Roll Tables</h4>
      <p class="table-hint">Select a table and mark it as a loot table, or assign it to NPCs.</p>
      <div class="table-select-row">
        <select class="world-table-select">
          {{#each worldTableGroups}}
            {{#if label}}
            <optgroup label="{{label}}">
              {{#each tables}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}{{#if isLoot}} ★{{/if}}</option>
              {{/each}}
            </optgroup>
            {{else}}
              {{#each tables}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}{{#if isLoot}} ★{{/if}}</option>
              {{/each}}
            {{/if}}
          {{/each}}
        </select>
        <button type="button" class="toggle-loot-flag" title="Toggle loot table flag"><i class="fas fa-star"></i> Loot</button>
      </div>
    </div>

    {{!-- Preview --}}
    {{#if selectedTablePreview}}
    <div class="table-preview">
      <div class="table-preview-header">
        <span class="preview-formula">{{selectedTablePreview.formula}}</span>
      </div>
      <div class="table-preview-rows">
        {{#each selectedTablePreview.rows}}
        <div class="preview-row">
          <span class="preview-range">{{range}}</span>
          {{#if img}}<img src="{{img}}" width="20" height="20" style="border-radius:2px; margin-right:4px;">{{/if}}
          <span class="preview-name">{{name}}</span>
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}
    {{else}}
    <p class="no-tables-msg"><em>No roll tables found. Build one in the Build Table tab or create one in Foundry's sidebar.</em></p>
    {{/if}}

    {{!-- NPC Assignment Section --}}
    {{#if hasLootTables}}
    <div class="world-tables-group" style="margin-top:8px;">
      <h4><i class="fas fa-skull-crossbones"></i> NPC Loot Assignment</h4>
      <p class="table-hint">Assign loot tables to NPCs. Only NPCs on the current scene are shown.</p>
      <div class="loot-npc-list">
        {{#each npcs}}
        <div class="loot-npc-row" style="display:flex; align-items:center; gap:6px; padding:3px 4px; border-bottom:1px solid rgba(255,255,255,0.05);">
          <img src="{{img}}" width="28" height="28" style="border-radius:3px;">
          <span style="flex:1; min-width:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">{{name}}</span>
          <select class="npc-table-select" data-actor-id="{{id}}" style="max-width:160px;">
            <option value="">— None —</option>
            {{#each ../lootTables}}
            <option value="{{uuid}}" {{#if (eq uuid ../currentTable)}}selected{{/if}}>{{name}}</option>
            {{/each}}
          </select>
          <input type="number" class="npc-chance-input" data-actor-id="{{id}}" value="{{dropChance}}" min="-1" max="100" style="width:50px;" title="Drop chance % (-1 = global)" />
        </div>
        {{/each}}
      </div>
    </div>
    {{/if}}

  </div>
  {{/unless}}

</form>
